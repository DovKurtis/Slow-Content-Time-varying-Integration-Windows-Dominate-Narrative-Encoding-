# === DYNAMIC ===
mdl2  = Ridge(alpha2).fit(X2_tr_z,  Y_tr_z);  Yh2 = mdl2.predict(X2_te_z)
mdl10 = Ridge(alpha10).fit(X10_tr_z, Y_tr_z); Yh10= mdl10.predict(X10_te_z)
mdl30 = Ridge(alpha30).fit(X30_tr_z, Y_tr_z); Yh30= mdl30.predict(X30_te_z)

def corr_1d(a,b): return np.corrcoef(a,b)[0,1]
r2_v  = [corr_1d(Y_te_z[:,v], Yh2[:,v])  for v in range(V)]
r10_v = [corr_1d(Y_te_z[:,v], Yh10[:,v]) for v in range(V)]
r30_v = [corr_1d(Y_te_z[:,v], Yh30[:,v]) for v in range(V)]
rbest = np.maximum.reduce([r2_v, r10_v, r30_v])
dyn_idx = np.argsort(rbest)[-int(TOP_PCT*V):]

y_true = Y_te_z[:,dyn_idx].mean(1)
y2     = Yh2[:,dyn_idx].mean(1)
y10    = Yh10[:,dyn_idx].mean(1)
y30    = Yh30[:,dyn_idx].mean(1)

def rolling_corr(x,y,win):
    n = len(x); res = np.full(n,np.nan)
    for i in range(win//2, n-win//2):
        a,b = x[i-win//2:i+win//2+1], y[i-win//2:i+win//2+1]
        res[i] = corr_1d(a,b)
    return res

r2_t  = rolling_corr(y_true,y2, WIN_TR)
r10_t = rolling_corr(y_true,y10,WIN_TR)
r30_t = rolling_corr(y_true,y30,WIN_TR)

def sigmoid(x,k=SIGMOID_K): return 1/(1+np.exp(-k*x))
def softmax_rows(M,tau=SOFTMAX_TAU):
    Z = (M / tau) - np.nanmax(M/tau,1,keepdims=True)
    E = np.exp(Z)
    return E / E.sum(1,keepdims=True)

P = softmax_rows(sigmoid(np.stack([r2_t,r10_t,r30_t],1)))

t = np.arange(split,T) * TR
plt.figure(figsize=(12,3))
plt.plot(t, P[:,0], "#d62728", lw=4, label="2s")
plt.plot(t, P[:,1], "#9467bd", lw=4, label="10s")
plt.plot(t, P[:,2], "#1f77b4", lw=4, label="30s")
plt.ylim(0,1)
plt.xlim(t[WIN_TR//2], t[-WIN_TR//2-1])
plt.xlabel("time (s)"); plt.ylabel("prob")
plt.title("Dynamic timescale weights (master ROI, test half)")
plt.legend(frameon=False)
plt.tight_layout()
plt.show()
